<UserControl
    x:Class="AvaloniaSample.VisualTest.Issue2131Repro.View"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Orientation="Horizontal"
        Spacing="80">

        <!--  Reporter's actual layout (issue #2131): the chart fills a wide, short
              "card row" — no explicit Width/Height on the chart, only
              MinHeight/MinWidth=100, exactly as in the reported XAML. The host
              stays laid out small so the bug still occurs; the Viewbox only
              magnifies the rendered output 3x. ClipToBounds=False so the
              value-gauge blob escaping the chart bounds stays visible — that is
              the reporter's actual symptom.  -->
        <StackPanel ClipToBounds="False">
            <TextBlock Text="240 x 100 card row (rendered 3x)" HorizontalAlignment="Center" Margin="0,0,0,260" />
            <Viewbox Width="720" Height="300" ClipToBounds="False">
                <Grid
                    Width="240"
                    Height="100"
                    Background="#33000000"
                    ClipToBounds="False">
                    <lvc:PieChart
                        x:Name="constrainedChart"
                        InitialRotation="270"
                        LegendPosition="Hidden"
                        MaxAngle="360"
                        MaxValue="100"
                        MinHeight="100"
                        MinValue="0"
                        MinWidth="100"
                        TooltipPosition="Hidden" />
                </Grid>
            </Viewbox>
        </StackPanel>

        <!--  Control: same setup with ample space, should look correct  -->
        <StackPanel>
            <TextBlock Text="400 x 310 card row (control)" HorizontalAlignment="Center" Margin="0,0,0,12" />
            <Grid Width="400" Height="310" Background="#33000000">
                <lvc:PieChart
                    x:Name="controlChart"
                    InitialRotation="270"
                    LegendPosition="Hidden"
                    MaxAngle="360"
                    MaxValue="100"
                    MinHeight="100"
                    MinValue="0"
                    MinWidth="100"
                    TooltipPosition="Hidden" />
            </Grid>
        </StackPanel>

    </StackPanel>
</UserControl>
