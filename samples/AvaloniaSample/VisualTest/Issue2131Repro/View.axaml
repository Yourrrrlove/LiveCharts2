<UserControl
    x:Class="AvaloniaSample.VisualTest.Issue2131Repro.View"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="using:LiveChartsCore.SkiaSharpView.Avalonia">

    <StackPanel
        HorizontalAlignment="Center"
        VerticalAlignment="Center"
        Orientation="Horizontal"
        Spacing="40">

        <!--  Constrained 110 x 110 wrapper — reporter's setup  -->
        <StackPanel>
            <TextBlock Text="110 x 110 wrapper" HorizontalAlignment="Center" />
            <Grid Width="110" Height="110" Background="#33000000">
                <lvc:PieChart
                    x:Name="constrainedChart"
                    InitialRotation="270"
                    LegendPosition="Hidden"
                    MaxAngle="360"
                    MaxValue="100"
                    MinHeight="100"
                    MinValue="0"
                    TooltipPosition="Hidden">
                    <lvc:PieChart.Series>
                        <lvc:XamlGaugeSeries
                            Fill="{lvc:SolidColorPaint Color='#1E90FF'}"
                            GaugeValue="100"
                            InnerRadius="38"
                            RelativeInnerRadius="-4"
                            MaxRadialColumnWidth="5"
                            ShowDataLabels="False" />
                        <lvc:XamlGaugeBackgroundSeries
                            Fill="{lvc:SolidColorPaint Color='#A9A9A9'}"
                            InnerRadius="40"
                            RelativeInnerRadius="4"
                            OuterRadiusOffset="-20"
                            MaxRadialColumnWidth="5" />
                    </lvc:PieChart.Series>
                </lvc:PieChart>
            </Grid>
        </StackPanel>

        <!--  Larger 300 x 300 wrapper — control, should look correct  -->
        <StackPanel>
            <TextBlock Text="300 x 300 wrapper (control)" HorizontalAlignment="Center" />
            <Grid Width="300" Height="300" Background="#33000000">
                <lvc:PieChart
                    InitialRotation="270"
                    LegendPosition="Hidden"
                    MaxAngle="360"
                    MaxValue="100"
                    MinValue="0"
                    TooltipPosition="Hidden">
                    <lvc:PieChart.Series>
                        <lvc:XamlGaugeSeries
                            Fill="{lvc:SolidColorPaint Color='#1E90FF'}"
                            GaugeValue="100"
                            InnerRadius="38"
                            RelativeInnerRadius="-4"
                            MaxRadialColumnWidth="5"
                            ShowDataLabels="False" />
                        <lvc:XamlGaugeBackgroundSeries
                            Fill="{lvc:SolidColorPaint Color='#A9A9A9'}"
                            InnerRadius="40"
                            RelativeInnerRadius="4"
                            OuterRadiusOffset="-20"
                            MaxRadialColumnWidth="5" />
                    </lvc:PieChart.Series>
                </lvc:PieChart>
            </Grid>
        </StackPanel>

    </StackPanel>
</UserControl>
